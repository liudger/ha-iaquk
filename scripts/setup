#!/usr/bin/env bash
# Setups the development environment.

# Stop on errors
set -e

ROOT="$( cd "$( dirname "$(readlink -f "$0")" )/.." >/dev/null 2>&1 && pwd )"
cd "${ROOT}"

uv_version="${UV_VERSION:-0.11.8}"
# Avoid PYTHON_VERSION: some devcontainer base images export it for their
# system interpreter, which can conflict with the project requirement.
python_version="${SETUP_PYTHON_VERSION:-3.14}"

# Load common functions
source ./scripts/_common

if ! command -v uv >/dev/null 2>&1; then
    log.info "Installing uv..."
    curl -LsSf "https://astral.sh/uv/${uv_version}/install.sh" | sh
    export PATH="${HOME}/.local/bin:${PATH}"
fi

uv=$(command -v uv)
export UV_PROJECT_ENVIRONMENT="${ROOT}/venv"

log.info "Syncing development environment..."
${uv} sync --python "${python_version}" --group dev

log.info "Installing git hooks..."
${uv} run prek install

echo '"""Custom components module."""' >custom_components/__init__.py
